# ── Runtime artifacts ────────────────────────────────────────────────────────
.demo-runs/
runs/
projects/*/runs/
projects/*/state/queue/*/*.json
projects/*/state/hooks/*/*.json
projects/*/state/approvals/*/*.json
projects/*/state/review_cadence.json
projects/*/state/metrics_snapshot.json

# ── Python ───────────────────────────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo

# ── Session / personal workspace files ──────────────────────────────────────
AGENTS.md
CLAUDE.md
CONTINUITY.md
TASKS.md
SESSION*.md
README-*.md
*_REPORT.md

# ── Personal dev scripts ─────────────────────────────────────────────────────
_system/scripts/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── User project workspaces (local only, not for GitHub) ─────────────────────
# Heavy runtime artifacts are ignored above; keep project docs trackable.
!projects/_template/
!projects/_template/**
!projects/*/docs/
!projects/*/docs/**
