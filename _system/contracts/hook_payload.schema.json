{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HookPayload",
  "type": "object",
  "required": ["hook_id", "run_id", "event_type", "event_version", "idempotency_key", "delivery_attempts", "max_delivery_attempts"],
  "properties": {
    "hook_id": { "type": "string" },
    "run_id": { "type": "string" },
    "event_type": { "type": "string" },
    "event_version": { "type": "string" },
    "idempotency_key": { "type": "string" },
    "delivery_attempts": { "type": "integer", "minimum": 0 },
    "max_delivery_attempts": { "type": "integer", "minimum": 1 },
    "dead_letter": { "type": "boolean" },
    "hook_version": { "type": "integer" },
    "event": { "type": "string" },
    "project": { "type": "string" },
    "run_date": { "type": "string" },
    "task_id": { "type": "string" },
    "task_title": { "type": "string" },
    "preferred_agent": { "type": "string" },
    "run_status": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "summary": { "type": "string" },
    "timestamps": {
      "type": "object",
      "properties": {
        "run_created_at": { "type": ["string", "null"] },
        "started_at": { "type": ["string", "null"] },
        "finished_at": { "type": ["string", "null"] }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "run_dir": { "type": "string" },
        "job_path": { "type": "string" },
        "meta_path": { "type": "string" },
        "result_path": { "type": "string" },
        "report_path": { "type": "string" },
        "stdout_path": { "type": "string" },
        "stderr_path": { "type": "string" }
      }
    },
    "delivery": {
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["pending", "sent", "failed"] },
        "attempt_count": { "type": "integer", "minimum": 0 },
        "last_attempt_at": { "type": ["string", "null"] },
        "sent_at": { "type": ["string", "null"] },
        "last_error": { "type": "string" }
      }
    },
    "delivery_attempt_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "attempt": { "type": "integer" },
          "attempted_at": { "type": "string" },
          "command": { "type": "string" },
          "timeout_seconds": { "type": "integer" },
          "exit_code": { "type": "integer" },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" },
          "outcome": { "type": "string" }
        }
      }
    }
  }
}
