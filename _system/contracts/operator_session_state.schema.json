{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:claw:operator_session_state.schema.json",
  "title": "Claw Operator Session State",
  "type": "object",
  "required": [
    "session_version",
    "session_id",
    "scope_key",
    "scope",
    "engine",
    "binding",
    "status",
    "created_at",
    "updated_at",
    "resume",
    "handoff",
    "reset_count",
    "rotation_count",
    "events"
  ],
  "properties": {
    "session_version": {
      "const": 1
    },
    "session_id": {
      "type": "string"
    },
    "scope_key": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      }
    },
    "engine": {
      "type": "string"
    },
    "binding": {
      "type": "object",
      "required": ["agent"],
      "properties": {
        "project": {
          "type": ["string", "null"]
        },
        "project_root": {
          "type": ["string", "null"]
        },
        "agent": {
          "type": "string"
        },
        "branch": {
          "type": ["string", "null"]
        },
        "workspace_mode": {
          "type": ["string", "null"]
        },
        "ctx_footer": {
          "type": ["string", "null"]
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "reset"]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "resume": {
      "type": ["object", "null"],
      "properties": {
        "provider": {
          "type": ["string", "null"]
        },
        "kind": {
          "type": ["string", "null"]
        },
        "handle": {
          "type": ["string", "null"]
        },
        "data": {
          "type": ["object", "null"]
        }
      }
    },
    "handoff": {
      "type": "object",
      "required": ["summary", "updated_at"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "run_id": {
          "type": ["string", "null"]
        },
        "run_path": {
          "type": ["string", "null"]
        },
        "note": {
          "type": ["string", "null"]
        }
      }
    },
    "last_run_id": {
      "type": ["string", "null"]
    },
    "last_run_path": {
      "type": ["string", "null"]
    },
    "reset_count": {
      "type": "integer",
      "minimum": 0
    },
    "rotation_count": {
      "type": "integer",
      "minimum": 0
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["at", "event"],
        "properties": {
          "at": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "enum": ["created", "updated", "reset", "rotated"]
          },
          "run_id": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "previous_session_id": {
            "type": "string"
          }
        }
      }
    }
  }
}
