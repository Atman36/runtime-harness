{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Session Docs Manifest",
  "type": "object",
  "required": [
    "session_docs_version",
    "task_id",
    "project",
    "created_at",
    "updated_at",
    "documents"
  ],
  "properties": {
    "session_docs_version": {
      "type": "integer",
      "const": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "bytes",
          "sha256",
          "updated_at"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "minLength": 64,
            "maxLength": 64
          },
          "updated_at": {
            "type": "string",
            "minLength": 1
          },
          "author": {
            "type": [
              "string",
              "null"
            ]
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          },
          "format": {
            "type": "string"
          },
          "section_count": {
            "type": "integer",
            "minimum": 0
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "template_path": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
