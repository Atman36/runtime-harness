{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:claw:wake_item.schema.json",
  "title": "Claw Wake Queue Item",
  "type": "object",
  "required": [
    "wake_version",
    "wake_id",
    "scope_key",
    "scope",
    "status",
    "created_at",
    "updated_at",
    "coalesced_count",
    "reason_counts",
    "events"
  ],
  "properties": {
    "wake_version": {
      "const": 1
    },
    "wake_id": {
      "type": "string"
    },
    "scope_key": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": ["agent", "task_id"],
      "properties": {
        "agent": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        }
      }
    },
    "status": {
      "const": "pending"
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "last_reason": {
      "type": ["string", "null"],
      "enum": ["timer", "assignment", "mention", "manual", "approval", null]
    },
    "coalesced_count": {
      "type": "integer",
      "minimum": 1
    },
    "reason_counts": {
      "type": "object",
      "required": ["timer", "assignment", "mention", "manual", "approval"],
      "properties": {
        "timer": {
          "type": "integer",
          "minimum": 0
        },
        "assignment": {
          "type": "integer",
          "minimum": 0
        },
        "mention": {
          "type": "integer",
          "minimum": 0
        },
        "manual": {
          "type": "integer",
          "minimum": 0
        },
        "approval": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["at", "reason"],
        "properties": {
          "at": {
            "type": "string"
          },
          "reason": {
            "type": "string",
            "enum": ["timer", "assignment", "mention", "manual", "approval"]
          },
          "run_id": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "context": {
            "type": "object"
          }
        }
      }
    }
  }
}
